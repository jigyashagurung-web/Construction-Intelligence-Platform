{
  "name": "@cip/ui",
  "version": "0.1.0",
  "description": "CIP Design System — construction intelligence platform component library",
  "type": "module",
  "license": "UNLICENSED",

  "main":    "./dist/index.cjs",
  "module":  "./dist/index.mjs",
  "types":   "./dist/types/index.d.ts",

  "exports": {
    ".": {
      "import":  "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types":   "./dist/types/index.d.ts"
    },
    "./style.css":      "./dist/style.css",
    "./dist/style.css": "./dist/style.css",
    "./tokens/*":       "./src/tokens/*"
  },

  "files": [
    "dist",
    "src/tokens",
    "src/styles/index.css"
  ],

  "sideEffects": [
    "*.css",
    "dist/style.css"
  ],

  "scripts": {
    "build":          "vite build --config vite.config.lib.ts && tsc --project tsconfig.build.json",
    "build:watch":    "vite build --config vite.config.lib.ts --watch",
    "storybook":      "storybook dev -p 6006",
    "build-storybook":"storybook build -o ../../storybook-static",
    "test-storybook": "test-storybook",
    "typecheck":      "tsc --noEmit"
  },

  "dependencies": {
    "@radix-ui/react-accordion":     "^1.2.0",
    "@radix-ui/react-avatar":        "^1.1.0",
    "@radix-ui/react-checkbox":      "^1.1.0",
    "@radix-ui/react-dialog":        "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-label":         "^2.1.0",
    "@radix-ui/react-popover":       "^1.1.0",
    "@radix-ui/react-progress":      "^1.1.0",
    "@radix-ui/react-select":        "^2.1.0",
    "@radix-ui/react-separator":     "^1.1.0",
    "@radix-ui/react-slot":          "^1.1.0",
    "@radix-ui/react-switch":        "^1.1.0",
    "@radix-ui/react-tabs":          "^1.1.0",
    "@radix-ui/react-tooltip":       "^1.1.0",
    "@tanstack/react-table":          "^8.20.0",
    "class-variance-authority":      "^0.7.1",
    "clsx":                          "^2.1.1",
    "lucide-react":                  "^0.447.0",
    "tailwind-merge":                "^2.5.2"
  },

  "peerDependencies": {
    "react":     "^18.0.0",
    "react-dom": "^18.0.0"
  },

  "devDependencies": {
    "@chromatic-com/storybook":       "^2.0.0",
    "@storybook/addon-a11y":          "^8.3.0",
    "@storybook/addon-docs":          "^8.3.0",
    "@storybook/addon-interactions":  "^8.3.0",
    "@storybook/addon-viewport":      "^8.3.0",
    "@storybook/manager-api":         "^8.3.0",
    "@storybook/react":               "^8.3.0",
    "@storybook/react-vite":          "^8.3.0",
    "@storybook/test":                "^8.3.0",
    "@storybook/theming":             "^8.3.0",
    "@storybook/types":               "^8.3.0",
    "@types/react":                   "^18.3.0",
    "@types/react-dom":               "^18.3.0",
    "@vitejs/plugin-react":           "^4.3.0",
    "autoprefixer":                   "^10.4.20",
    "postcss":                        "^8.4.47",
    "react":                          "^18.3.0",
    "react-dom":                      "^18.3.0",
    "storybook":                      "^8.3.0",
    "tailwindcss":                    "^3.4.13",
    "typescript":                     "^5.4.0",
    "vite":                           "^5.4.0"
  }
}
