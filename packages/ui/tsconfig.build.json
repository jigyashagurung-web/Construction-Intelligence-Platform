{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": { "@/*": ["./src/*"] },

    /* Override noEmit so declarations are emitted */
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationDir": "./dist/types",
    "outDir": "./dist",

    /* allowImportingTsExtensions requires noEmit or emitDeclarationOnly — satisfied above */
    "allowImportingTsExtensions": true
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "dist",
    "storybook-static",
    "src/**/*.stories.tsx",
    "src/**/*.stories.ts",
    ".storybook"
  ]
}
